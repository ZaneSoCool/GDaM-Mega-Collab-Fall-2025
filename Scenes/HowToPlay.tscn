horizontal_alignment = 1

[node name="slotsBody" type="Label" parent="HBoxContainer/VBoxContainer" unique_id=741569047]
layout_mode = 2
text = "After you win a round against the house, you will be led towards the slots. You can spend your vitality to spin and win some powerups. Match 3 symbols from left to right to win.

You start off with only the middle row, but you can spend extra vitality to unlock more rows. They are only unlocked for that round. 

Smiley faces are \"wild.\" They match with any symbol. "
autowrap_mode = 3

