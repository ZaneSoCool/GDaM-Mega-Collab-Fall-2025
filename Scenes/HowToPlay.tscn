[node name="bjBody" type="Label" parent="HBoxContainer/VBoxContainer2" unique_id=662874435]
layout_mode = 2
text = "Each round, you will go up against the dealer in a standard round of blackjack. Place a bet (with your own health or \"vitality\"), and get as close to 21 as possible without busting. 

After you're dealt your first two cards, you can either \"hit\" for another card, \"stand\" and stop drawing cards, or \"double down,\" where you double your wager and draw one more card.

Ties go to the dealer. If you're closer to 21 without going over, you gain vitality and the dealer loses the same amount you bet. Try and get their vitality to zero. Use your powerups to get the upper hand."
autowrap_mode = 3

